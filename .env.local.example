# ─────────────────────────────────────────────
# VIDEO SOURCE
# Options: local | youtube | s3 | supabase
# Leave as "local" to use files from public/videos/
# ─────────────────────────────────────────────
NEXT_PUBLIC_VIDEO_SOURCE=local

# ─────────────────────────────────────────────
# YOUTUBE (optional — for YouTube-hosted videos)
# Get from https://console.cloud.google.com → YouTube Data API v3
# ─────────────────────────────────────────────
YOUTUBE_API_KEY=
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=
NEXT_PUBLIC_YOUTUBE_PLAYLIST_ID=

# ─────────────────────────────────────────────
# AWS S3 (optional — for S3-hosted videos)
# Also works with Cloudflare R2 (set S3_ENDPOINT)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# For Cloudflare R2 or other S3-compatible storage:
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ─────────────────────────────────────────────
# SUPABASE (optional — for auth, DB, and Supabase Storage)
# Get from https://supabase.com → Project Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# GOOGLE CALENDAR / CAL.COM (Phase 2 — booking)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CALCOM_API_KEY=

# ─────────────────────────────────────────────
# NEXTAUTH — credentials-based auth (required)
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# On production set NEXTAUTH_URL to your domain
# ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ─────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
